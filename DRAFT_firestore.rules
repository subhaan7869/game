rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "hassennabeel9@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid == request.auth.uid &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('deliveries' in data) || (data.deliveries is number && data.deliveries >= 0)) &&
             (!('walletBalance' in data) || (data.walletBalance is number && data.walletBalance >= 0)) &&
             (!('role' in data) || data.role == 'driver'); // Prevent self-assigning admin
    }

    function isValidScheduledOrder(data) {
      return data.driverUid is string && data.driverUid == request.auth.uid &&
             data.restaurantName is string && data.restaurantName.size() > 0 && 
             data.restaurantName.size() < 200 &&
             // Handle both native timestamp and ISO string if necessary, 
             // but app sends ISO string. For 'is timestamp' check, we prefer native.
             // However, for string validation:
             data.scheduledTime is string && data.scheduledTime.size() < 50 &&
             data.status in ['pending', 'active', 'completed'];
    }

    function isValidActiveOrder(data) {
      return data.driverUid is string && data.driverUid == request.auth.uid &&
             data.restaurantName is string && data.restaurantName.size() > 0 &&
             data.status in ['accepted', 'picked_up', 'arrived', 'completed', 'returning_to_restaurant'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().keys().hasAll(['uid', 'name']) && 
                    !('role' in incoming());
      
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) &&
                    !affectedKeys().hasAny(['uid', 'role']);
    }

    match /scheduled_orders/{orderId} {
      allow get: if isAuthenticated() && (existing().driverUid == request.auth.uid || isAdmin());
      allow list: if isAuthenticated() && (resource.data.driverUid == request.auth.uid || isAdmin());
      
      allow create: if isAuthenticated() && isValidScheduledOrder(incoming());
      
      allow update: if isAuthenticated() && (existing().driverUid == request.auth.uid || isAdmin()) && 
                    isValidScheduledOrder(incoming()) &&
                    !affectedKeys().hasAny(['driverUid']);
      
      allow delete: if isAuthenticated() && (existing().driverUid == request.auth.uid || isAdmin());
    }

    match /carplay_sync/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      allow write: if isOwner(userId) && incoming().driverUid == userId;
    }

    match /active_orders/{orderId} {
      allow get: if isAuthenticated() && (existing().driverUid == request.auth.uid || isAdmin());
      allow list: if isAuthenticated() && (resource.data.driverUid == request.auth.uid || isAdmin());
      
      allow create: if isAuthenticated() && isValidActiveOrder(incoming());
      allow update: if isAuthenticated() && (existing().driverUid == request.auth.uid || isAdmin()) && 
                    isValidActiveOrder(incoming()) &&
                    !affectedKeys().hasAny(['driverUid']);
      allow delete: if isAuthenticated() && (existing().driverUid == request.auth.uid || isAdmin());
    }
  }
}
